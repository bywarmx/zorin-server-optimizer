#!/bin/bash

# Colores para la terminal
VERDE="\e[0;32m"
ROJO="\e[0;31m"
AZUL="\e[0;34m"
AMARILLO="\e[0;33m"
RESET="\e[0m"

# Validar si se ejecuta como root (requerido para modificar systemd)
if [ "$EUID" -ne 0 ]; then
  echo -e "${ROJO}Error: Este script debe ser ejecutado con privilegios de root (usa sudo).${RESET}"
  echo -e "Ejemplo: sudo $0 [opción]"
  exit 1
fi

# Detectar el usuario real que invocó sudo o usar por defecto
USUARIO_REAL=${SUDO_USER:-$(logname 2>/dev/null)}
if [ -z "$USUARIO_REAL" ] || [ "$USUARIO_REAL" = "root" ]; then
  USUARIO_REAL="bywarrior"
fi

mostrar_ayuda() {
  echo -e "${AZUL}Modo Servidor para Zorin OS / Ubuntu / Debian${RESET}"
  echo -e "Uso: sudo $0 [comando]"
  echo ""
  echo "Comandos disponibles:"
  echo "  enable   - Activa el modo servidor (desactiva interfaz gráfica y configura autologin)"
  echo "  disable  - Desactiva el modo servidor (activa interfaz gráfica y elimina autologin)"
  echo "  status   - Muestra el estado actual del modo servidor"
  echo "  help     - Muestra esta ayuda"
  echo ""
  echo "Si no se especifica ningún comando, se iniciará el menú interactivo."
}

mostrar_estado() {
  echo -e "${AZUL}=== Estado del Modo Servidor ===${RESET}"
  
  # Target actual
  TARGET_DEFAULT=$(systemctl get-default)
  echo -ne "Arranque por defecto: "
  if [ "$TARGET_DEFAULT" = "multi-user.target" ]; then
    echo -e "${VERDE}Modo Servidor (Consola / multi-user.target)${RESET}"
  elif [ "$TARGET_DEFAULT" = "graphical.target" ]; then
    echo -e "${AMARILLO}Modo Escritorio (Gráfico / graphical.target)${RESET}"
  else
    echo -e "${ROJO}Otro ($TARGET_DEFAULT)${RESET}"
  fi

  # Autologin en TTY1
  DIR_OVERRIDE="/etc/systemd/system/getty@tty1.service.d"
  if [ -f "$DIR_OVERRIDE/override.conf" ]; then
    USER_AUTOLOGIN=$(grep -oP '(?<=--autologin )[^\s]+' "$DIR_OVERRIDE/override.conf")
    echo -e "Autologin en TTY1: ${VERDE}Activo${RESET} (Usuario: ${AMARILLO}$USER_AUTOLOGIN${RESET})"
  else
    echo -e "Autologin en TTY1: ${ROJO}Inactivo${RESET}"
  fi
}

aplicar_optimizacion() {
  echo -e "\n${AZUL}[*] Activando el Modo Servidor...${RESET}"

  # 1. Configurar autologin en TTY1
  echo -e "${AZUL}[*] Configurando inicio automático para el usuario: ${AMARILLO}$USUARIO_REAL${RESET}..."
  DIR_OVERRIDE="/etc/systemd/system/getty@tty1.service.d"
  mkdir -p "$DIR_OVERRIDE"
  
  cat <<EOF > "$DIR_OVERRIDE/override.conf"
[Service]
ExecStart=
ExecStart=-/sbin/agetty --noclear --autologin $USUARIO_REAL %I \$TERM
EOF

  if [ $? -eq 0 ]; then
    echo -e "${VERDE}[✓] Autologin configurado con éxito.${RESET}"
  else
    echo -e "${ROJO}[✗] Error al configurar el autologin.${RESET}"
    exit 1
  fi

  # 2. Recargar systemd
  echo -e "${AZUL}[*] Recargando systemd...${RESET}"
  systemctl daemon-reload

  # 3. Cambiar target por defecto a modo consola
  echo -e "${AZUL}[*] Configurando arranque por defecto en modo consola...${RESET}"
  systemctl set-default multi-user.target

  if [ $? -eq 0 ]; then
    echo -e "${VERDE}[✓] Sistema configurado para arrancar en modo consola.${RESET}"
  else
    echo -e "${ROJO}[✗] Error al cambiar la configuración de arranque.${RESET}"
    exit 1
  fi

  echo -e "\n${VERDE}=====================================================${RESET}"
  echo -e "${VERDE}¡Modo Servidor activado con éxito!${RESET}"
  echo -e "Al reiniciar, iniciará directo en modo consola sin interfaz gráfica."
  echo -e "====================================================="
}

revertir_optimizacion() {
  echo -e "\n${AZUL}[*] Desactivando el Modo Servidor... Volviendo a Modo Escritorio...${RESET}"

  # 1. Eliminar regla de autologin
  DIR_OVERRIDE="/etc/systemd/system/getty@tty1.service.d"
  if [ -d "$DIR_OVERRIDE" ]; then
    echo -e "${AZUL}[*] Eliminando autologin en consola...${RESET}"
    rm -rf "$DIR_OVERRIDE"
    echo -e "${VERDE}[✓] Autologin desactivado.${RESET}"
  else
    echo -e "${AMARILLO}[!] Autologin ya estaba desactivado.${RESET}"
  fi

  # 2. Recargar systemd
  echo -e "${AZUL}[*] Recargando systemd...${RESET}"
  systemctl daemon-reload

  # 3. Cambiar target por defecto a modo gráfico
  echo -e "${AZUL}[*] Configurando arranque por defecto en modo gráfico...${RESET}"
  systemctl set-default graphical.target

  if [ $? -eq 0 ]; then
    echo -e "${VERDE}[✓] Sistema configurado para arrancar en modo gráfico.${RESET}"
  else
    echo -e "${ROJO}[✗] Error al restaurar el modo gráfico.${RESET}"
    exit 1
  fi

  echo -e "\n${VERDE}=====================================================${RESET}"
  echo -e "${VERDE}¡Modo Escritorio restaurado con éxito!${RESET}"
  echo -e "Al reiniciar, cargará el entorno de escritorio habitual.${RESET}"
  echo -e "====================================================="
}

# Flujo principal basado en argumentos
if [ $# -gt 0 ]; then
  case $1 in
    enable)
      aplicar_optimizacion
      ;;
    disable)
      revertir_optimizacion
      ;;
    status)
      mostrar_estado
      ;;
    help|-h|--help)
      mostrar_ayuda
      ;;
    *)
      echo -e "${ROJO}Comando desconocido: $1${RESET}"
      mostrar_ayuda
      exit 1
      ;;
  esac
else
  # Menú interactivo si se ejecuta sin argumentos
  echo -e "${AZUL}=====================================================${RESET}"
  echo -e "${VERDE}               Gestor de Modo Servidor               ${RESET}"
  echo -e "${AZUL}=====================================================${RESET}"
  echo -e "1) Activar Modo Servidor (Consola + Autologin)"
  echo -e "2) Desactivar Modo Servidor (Restaurar Escritorio)"
  echo -e "3) Ver Estado Actual"
  echo -e "4) Salir"
  echo -e "-----------------------------------------------------"
  read -p "Selecciona una opción [1-4]: " opcion < /dev/tty

  case $opcion in
    1)
      aplicar_optimizacion
      read -p "¿Deseas reiniciar el sistema ahora? (s/n): " opt_reboot < /dev/tty
      if [[ "$opt_reboot" =~ ^[Ss]$ ]]; then
        reboot
      fi
      ;;
    2)
      revertir_optimizacion
      read -p "¿Deseas reiniciar el sistema ahora? (s/n): " opt_reboot < /dev/tty
      if [[ "$opt_reboot" =~ ^[Ss]$ ]]; then
        reboot
      fi
      ;;
    3)
      mostrar_estado
      ;;
    4|*)
      echo "Saliendo sin realizar cambios."
      exit 0
      ;;
  esac
fi
